# Copy this file to '.env' and fill in your actual API keys.
# Do NOT commit the '.env' file to your Git repository!

# 1. Google Gemini API Key (Required)
GOOGLE_LLM_API_KEY=AIzaSyYourActualAPIKeyHere

# 2. Model Selection (Default: gemini-3.1-flash-lite)
GOOGLE_LLM_MODEL=gemini-3.1-flash-lite

# 3. Allowed CORS Origins (Comma separated list, e.g. http://localhost:3000,http://127.0.0.1:5500)
# Use '*' to allow all origins for testing, but restrict in production!
ALLOWED_ORIGINS=*
